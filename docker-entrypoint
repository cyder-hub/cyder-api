#!/bin/sh
set -eu

DATA_DIR="${CYDER_DATA_DIR:-/data/cyder}"
export CYDER_DATA_DIR="$DATA_DIR"

mkdir -p \
  "$DATA_DIR/config" \
  "$DATA_DIR/db" \
  "$DATA_DIR/storage" \
  /tmp/cyder-api

if [ "$(id -u)" = "0" ]; then
  chown -R cyder:cyder "$DATA_DIR" /tmp/cyder-api
  exec su-exec cyder "$@"
fi

exec "$@"
